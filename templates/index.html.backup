const canvas=document.getElementById('canvas');
const renderer=new THREE.WebGLRenderer({canvas,alpha:true});
renderer.setSize(window.innerWidth,window.innerHeight);
renderer.setClearColor(0x89CFF0,0);
const scene=new THREE.Scene();
const camera=new THREE.PerspectiveCamera(45,window.innerWidth/window.innerHeight,0.1,1000);
camera.position.set(0,0,6);
const light=new THREE.PointLight(0xffffff,1);
light.position.set(2,3,4);
scene.add(light);
scene.add(new THREE.AmbientLight(0x404060));
const sphereMat=new THREE.MeshPhongMaterial({color:0x00B4D8,emissive:0x004466,shininess:90});
const sphere=new THREE.Mesh(new THREE.SphereGeometry(1.4,64,64),sphereMat);
scene.add(sphere);
const wireMat=new THREE.MeshBasicMaterial({color:0xffffff,wireframe:true,transparent:true,opacity:0.3});
const wireframe=new THREE.Mesh(new THREE.SphereGeometry(1.42,24,24),wireMat);
scene.add(wireframe);
const particlesGeo=new THREE.BufferGeometry();
const positions=[];
for(let i=0;i<800;i++){positions.push((Math.random()-0.5)*8);positions.push((Math.random()-0.5)*8);positions.push((Math.random()-0.5)*8);}
particlesGeo.setAttribute('position',new THREE.BufferAttribute(new Float32Array(positions),3));
const particles=new THREE.Points(particlesGeo,new THREE.PointsMaterial({color:0xffffff,size:0.05}));
scene.add(particles);
let time=0;
function animate(){requestAnimationFrame(animate);time+=0.01;sphere.rotation.y=time*0.3;wireframe.rotation.y=time*0.25;particles.rotation.y=time*0.05;renderer.render(scene,camera);}
animate();
window.addEventListener('resize',()=>{renderer.setSize(window.innerWidth,window.innerHeight);camera.aspect=window.innerWidth/window.innerHeight;camera.updateProjectionMatrix();});
const logsDiv=document.getElementById('logs');
const threatEl=document.getElementById('threat');
const stepsEl=document.getElementById('steps');
const statusEl=document.getElementById('status');
function addLog(msg){const div=document.createElement('div');div.className='log-entry';div.textContent=`[${new Date().toLocaleTimeString()}] ${msg}`;logsDiv.appendChild(div);div.scrollIntoView({behavior:'smooth'});}
function sleep(ms){return new Promise(resolve=>setTimeout(resolve,ms));}
async function setStep(step){stepsEl.textContent=step;statusEl.textContent=step===5?'SECURE':(step===0?'RUN':'PROCESSING');}
document.getElementById('run').addEventListener('click',async()=>{
const cmd=document.getElementById('command').value.trim();
if(!cmd){addLog('❌ Please enter a command');return;}
addLog(`📝 Command: "${cmd}"`);
await setStep(0);
let threat=14;
const cmdLow=cmd.toLowerCase();
if(cmdLow.includes('rm')||cmdLow.includes('delete')||cmdLow.includes('drop')){threat=95;addLog('⚠️ CRITICAL: Destructive command detected!');}
else if(cmdLow.includes('sudo')||cmdLow.includes('admin')){threat=75;addLog('⚠️ HIGH RISK: Privilege escalation attempt!');}
else if(cmdLow.includes('scan')){threat=30;addLog('🔍 Security scan requested');}
else{addLog('✅ Standard command');}
threatEl.textContent=threat+'%';
await sleep(500);
addLog('🛡 Zero-trust validation...');
await setStep(1);
await sleep(600);
addLog('📊 Risk analysis complete');
await setStep(2);
await sleep(500);
if(threat>80){addLog('🚫 BLOCKED: High risk command rejected');await setStep(4);addLog('❌ Pipeline terminated');statusEl.textContent='BLOCKED';return;}
addLog('☁️ Connecting to Foundry IQ...');
await setStep(3);
await sleep(500);
addLog('✅ Foundry grounding complete');
await sleep(400);
if(cmdLow.includes('scan')){addLog('🔎 Running vulnerability scan...');await sleep(600);addLog('📋 Found 2 vulnerabilities - patching...');}
else{addLog('⚙️ Executing command...');}
await setStep(4);
await sleep(500);
addLog('✅ Pipeline complete! Status: SECURE');
await setStep(5);
statusEl.textContent='SECURE';
});
</script>

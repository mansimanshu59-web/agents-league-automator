// ==================== CUSTOM CURSOR WITH TOUCH ====================
const glowCursor = document.getElementById('cursor-glow');
const coreCursor = document.getElementById('cursor-core');
const trailCursor = document.getElementById('cursor-trail');

let mouseX = 0, mouseY = 0;
let glowX = 0, glowY = 0;
let coreX = 0, coreY = 0;
let trailX = 0, trailY = 0;

function handleMove(e) {
  let clientX, clientY;
  if (e.touches) {
    clientX = e.touches[0].clientX;
    clientY = e.touches[0].clientY;
    createRipple(clientX, clientY);
  } else {
    clientX = e.clientX;
    clientY = e.clientY;
  }
  mouseX = clientX;
  mouseY = clientY;
}

function createRipple(x, y) {
  const ripple = document.createElement('div');
  ripple.className = 'touch-ripple';
  ripple.style.left = x + 'px';
  ripple.style.top = y + 'px';
  document.body.appendChild(ripple);
  setTimeout(() => ripple.remove(), 800);
}

document.addEventListener('mousemove', handleMove);
document.addEventListener('touchmove', handleMove);
document.addEventListener('touchstart', (e) => { if(e.touches) handleMove(e); });

function animateCursor() {
  glowX += (mouseX - glowX) * 0.1;
  glowY += (mouseY - glowY) * 0.1;
  coreX += (mouseX - coreX) * 0.25;
  coreY += (mouseY - coreY) * 0.25;
  trailX += (mouseX - trailX) * 0.06;
  trailY += (mouseY - trailY) * 0.06;
  
  glowCursor.style.left = glowX + 'px';
  glowCursor.style.top = glowY + 'px';
  coreCursor.style.left = coreX + 'px';
  coreCursor.style.top = coreY + 'px';
  trailCursor.style.left = trailX + 'px';
  trailCursor.style.top = trailY + 'px';
  
  requestAnimationFrame(animateCursor);
}
animateCursor();

// Hover effects
document.querySelectorAll('.run-btn, .iq-pill, .nav-links a, .metric-card, .cmd-card').forEach(el => {
  el.addEventListener('mouseenter', () => {
    glowCursor.style.width = '160px';
    glowCursor.style.height = '160px';
    coreCursor.style.width = '14px';
    coreCursor.style.height = '14px';
  });
  el.addEventListener('mouseleave', () => {
    glowCursor.style.width = '120px';
    glowCursor.style.height = '120px';
    coreCursor.style.width = '10px';
    coreCursor.style.height = '10px';
  });
});

// ==================== THREE.JS MAIN SPHERE ====================
const canvasMain = document.getElementById('three-canvas-main');
const rendererMain = new THREE.WebGLRenderer({ canvas: canvasMain, alpha: true });
let width = window.innerWidth;
let height = window.innerHeight;
rendererMain.setSize(width, height);
rendererMain.setClearColor(0x000000, 0);

const sceneMain = new THREE.Scene();
const cameraMain = new THREE.PerspectiveCamera(42, width/height, 0.1, 1000);
cameraMain.position.set(0, 1, 9);
cameraMain.lookAt(0, 0, 0);

// Main Sphere - Golden/Creamy
const mainMat = new THREE.MeshPhongMaterial({
  color: 0xD4A574,
  emissive: 0xC5A059,
  emissiveIntensity: 0.15,
  shininess: 85,
  transparent: true,
  opacity: 0.92
});
const mainSphere = new THREE.Mesh(new THREE.SphereGeometry(1.55, 128, 128), mainMat);
sceneMain.add(mainSphere);

// Inner Core
const coreMat = new THREE.MeshStandardMaterial({
  color: 0xC5A059,
  emissive: 0xD4A574,
  emissiveIntensity: 0.4,
  metalness: 0.7,
  roughness: 0.3
});
const core = new THREE.Mesh(new THREE.SphereGeometry(0.65, 64, 64), coreMat);
sceneMain.add(core);

// Multiple Wireframes
const wireColors = [0xC5A059, 0xD4A574, 0xA0845C];
for (let i = 0; i < 3; i++) {
  const wireMat = new THREE.MeshBasicMaterial({ color: wireColors[i], wireframe: true, transparent: true, opacity: 0.25 });
  const wireSphere = new THREE.Mesh(new THREE.SphereGeometry(1.65 + i * 0.12, 48, 48), wireMat);
  sceneMain.add(wireSphere);
}

// Rings
const ringMat = new THREE.MeshBasicMaterial({ color: 0xC5A059, transparent: true, opacity: 0.45 });
const rings = [];
const ringSizes = [2.1, 2.4, 2.7, 3.0, 3.3, 3.6];
ringSizes.forEach((size, idx) => {
  const ring = new THREE.Mesh(new THREE.TorusGeometry(size, 0.045, 64, 200), ringMat);
  ring.rotation.x = Math.PI / 2 + idx * 0.3;
  ring.rotation.z = idx * 0.5;
  sceneMain.add(ring);
  rings.push(ring);
});

// Orbiting Satellites
const satCount = 100;
const satellites = [];
for (let i = 0; i < satCount; i++) {
  const satMat = new THREE.MeshStandardMaterial({ color: 0xD4A574, emissive: 0xC5A059, emissiveIntensity: 0.2 });
  const sat = new THREE.Mesh(new THREE.SphereGeometry(0.07, 16, 16), satMat);
  sceneMain.add(sat);
  satellites.push({
    mesh: sat,
    radius: 2.2 + Math.random() * 1.5,
    speed: 0.25 + Math.random() * 0.4,
    angle: (i / satCount) * Math.PI * 2,
    ySpeed: 0.3 + Math.random() * 0.6
  });
}

// Lights
const ambientLight = new THREE.AmbientLight(0x332211);
sceneMain.add(ambientLight);
const light1 = new THREE.PointLight(0xC5A059, 0.9);
light1.position.set(3, 4, 5);
sceneMain.add(light1);
const light2 = new THREE.PointLight(0xD4A574, 0.7);
light2.position.set(-3, 2, 4);
sceneMain.add(light2);
const light3 = new THREE.PointLight(0xA0845C, 0.5);
light3.position.set(0, -3, 3);
sceneMain.add(light3);

// ==================== PARTICLE SYSTEM ====================
const canvasParticles = document.getElementById('three-canvas-particles');
const rendererParticles = new THREE.WebGLRenderer({ canvas: canvasParticles, alpha: true });
rendererParticles.setSize(width, height);
rendererParticles.setClearColor(0x000000, 0);

const sceneParticles = new THREE.Scene();
const cameraParticles = new THREE.PerspectiveCamera(45, width/height, 0.1, 1000);
cameraParticles.position.set(0, 0, 12);

// Floating particle cloud
const particleCount = 5000;
const particlesGeo = new THREE.BufferGeometry();
const particlePos = new Float32Array(particleCount * 3);
for (let i = 0; i < particleCount; i++) {
  const radius = 3.5 + Math.random() * 2.5;
  const theta = Math.random() * Math.PI * 2;
  const phi = Math.acos(2 * Math.random() - 1);
  particlePos[i*3] = radius * Math.sin(phi) * Math.cos(theta);
  particlePos[i*3+1] = radius * Math.sin(phi) * Math.sin(theta) * 0.8;
  particlePos[i*3+2] = radius * Math.cos(phi);
}
particlesGeo.setAttribute('position', new THREE.BufferAttribute(particlePos, 3));
const particleMat = new THREE.PointsMaterial({ color: 0xD4A574, size: 0.045, transparent: true, opacity: 0.35 });
const particleCloud = new THREE.Points(particlesGeo, particleMat);
sceneParticles.add(particleCloud);

// Starfield background
const starCount = 1500;
const starGeo = new THREE.BufferGeometry();
const starPositions = new Float32Array(starCount * 3);
for (let i = 0; i < starCount; i++) {
  starPositions[i*3] = (Math.random() - 0.5) * 200;
  starPositions[i*3+1] = (Math.random() - 0.5) * 120;
  starPositions[i*3+2] = (Math.random() - 0.5) * 80 - 40;
}
starGeo.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
const starMatObj = new THREE.PointsMaterial({ color: 0xC5A059, size: 0.12, transparent: true, opacity: 0.3 });
const starsField = new THREE.Points(starGeo, starMatObj);
sceneParticles.add(starsField);

// Animation
let timeVal = 0;

function animateAll() {
  requestAnimationFrame(animateAll);
  timeVal += 0.01;
  
  // Main sphere rotation
  mainSphere.rotation.y = timeVal * 0.18;
  mainSphere.rotation.x = Math.sin(timeVal * 0.12) * 0.08;
  core.rotation.y = timeVal * 0.45;
  core.rotation.x = timeVal * 0.3;
  
  // Rings rotation
  rings.forEach((ring, idx) => {
    ring.rotation.z = timeVal * (0.08 + idx * 0.04);
    ring.rotation.x = Math.sin(timeVal * 0.15) * 0.2 + Math.PI / 2 + idx * 0.1;
  });
  
  // Satellites orbit
  satellites.forEach(sat => {
    sat.angle += 0.01 * sat.speed;
    sat.mesh.position.x = Math.cos(sat.angle) * sat.radius;
    sat.mesh.position.z = Math.sin(sat.angle) * sat.radius;
    sat.mesh.position.y = Math.sin(sat.angle * sat.ySpeed) * 0.7;
  });
  
  // Particle cloud rotation
  particleCloud.rotation.y = timeVal * 0.025;
  particleCloud.rotation.x = Math.sin(timeVal * 0.04) * 0.08;
  starsField.rotation.y = timeVal * 0.01;
  
  // Pulsing lights
  light1.intensity = 0.7 + Math.sin(timeVal * 1.5) * 0.25;
  light2.intensity = 0.55 + Math.cos(timeVal * 1.3) * 0.2;
  
  // Camera floating
  cameraMain.position.x += (Math.sin(timeVal * 0.2) * 0.08 - cameraMain.position.x) * 0.03;
  cameraMain.position.y += (Math.sin(timeVal * 0.25) * 0.05 - cameraMain.position.y) * 0.03;
  cameraMain.lookAt(0, 0, 0);
  
  cameraParticles.position.x = Math.sin(timeVal * 0.1) * 0.3;
  cameraParticles.position.y = Math.sin(timeVal * 0.15) * 0.2;
  cameraParticles.lookAt(0, 0, 0);
  
  rendererMain.render(sceneMain, cameraMain);
  rendererParticles.render(sceneParticles, cameraParticles);
}
animateAll();

window.addEventListener('resize', () => {
  width = window.innerWidth;
  height = window.innerHeight;
  rendererMain.setSize(width, height);
  rendererParticles.setSize(width, height);
  cameraMain.aspect = width / height;
  cameraMain.updateProjectionMatrix();
  cameraParticles.aspect = width / height;
  cameraParticles.updateProjectionMatrix();
});

// ==================== APP LOGIC ====================
const logContainer = document.getElementById('logContainer');
const threatScoreEl = document.getElementById('threatScore');
const nodeCountEl = document.getElementById('nodeCount');
const pipelineStatusEl = document.getElementById('pipelineStatus');
const traceIdEl = document.getElementById('traceId');

function getTime() {
  const d = new Date();
  return `${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}:${String(d.getSeconds()).padStart(2,'0')}`;
}

function addLog(tagClass, tagText, message) {
  const entry = document.createElement('div');
  entry.className = 'log-entry';
  entry.innerHTML = `
    <span class="log-time">${getTime()}</span>
    <span class="log-tag ${tagClass}">${tagText}</span>
    <span class="log-message">${message}</span>
  `;
  logContainer.appendChild(entry);
  entry.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function setStep(stepIndex) {
  for (let i = 0; i < 5; i++) {
    const stepEl = document.getElementById(`step${i}`);
    const connEl = document.getElementById(`conn${i}`);
    if (i < stepIndex) {
      stepEl.className = 'step-icon completed';
      if (connEl) connEl.className = 'connector active';
    } else if (i === stepIndex) {
      stepEl.className = 'step-icon active';
      if (connEl) connEl.className = 'connector';
    } else {
      stepEl.className = 'step-icon idle';
      if (connEl) connEl.className = 'connector';
    }
  }
}

function updateNodes(count) {
  nodeCountEl.textContent = count;
  nodeCountEl.style.animation = 'none';
  nodeCountEl.offsetHeight;
  nodeCountEl.style.animation = 'numberPop 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55)';
}

function updateThreat(score) {
  threatScoreEl.textContent = score + '%';
  threatScoreEl.style.animation = 'none';
  threatScoreEl.offsetHeight;
  threatScoreEl.style.animation = 'numberPop 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55)';
}

function updateStatus(status) {
  pipelineStatusEl.textContent = status;
}

function sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

document.getElementById('runBtn').addEventListener('click', async () => {
  const command = document.getElementById('commandInput').value.trim();
  
  if (!command) {
    addLog('tag-audit', 'ERROR', '⚠ No command entered!');
    return;
  }
  
  addLog('tag-user', 'USER', `Command: "${command.substring(0, 60)}${command.length > 60 ? '...' : ''}"`);
  
  setStep(0);
  updateNodes(1);
  updateStatus('RUN');
  
  let threat = 14;
  const cmdLower = command.toLowerCase();
  
  if (cmdLower.includes('rm') || cmdLower.includes('delete') || cmdLower.includes('drop')) {
    threat = 95;
    addLog('tag-sec', 'SECURITY', `⚠ CRITICAL: Destructive command detected! Threat: ${threat}%`);
  } else if (cmdLower.includes('sudo') || cmdLower.includes('admin')) {
    threat = 75;
    addLog('tag-sec', 'SECURITY', `⚠ HIGH RISK: Privilege escalation attempt! Score: ${threat}%`);
  } else if (cmdLower.includes('scan') || cmdLower.includes('vuln')) {
    threat = 30;
    addLog('tag-sec', 'SECURITY', `🔍 Security scan requested. Threat: ${threat}%`);
  } else {
    addLog('tag-sec', 'SECURITY', `✅ Standard command. Threat: ${threat}%`);
  }
  
  updateThreat(threat);
  await sleep(600);
  
  setStep(1);
  updateNodes(2);
  addLog('tag-audit', 'AUDIT', '🛡 Zero-trust validation: Payload sanitized');
  await sleep(700);
  
  setStep(2);
  updateNodes(3);
  addLog('tag-audit', 'AUDIT', '📊 Risk analysis complete');
  await sleep(600);
  
  if (threat > 80) {
    addLog('tag-act', 'ACTION', `🚫 BLOCKED: Command rejected - CRITICAL risk`);
    setStep(4);
    updateNodes(5);
    updateStatus('BLOCKED');
    addLog('tag-audit', 'AUDIT', '❌ Pipeline terminated');
    traceIdEl.textContent = 'BLOCKED';
    return;
  }
  
  setStep(3);
  updateNodes(4);
  addLog('tag-foun', 'FOUNDRY', '☁ Connecting to Foundry IQ knowledge graph...');
  await sleep(500);
  addLog('tag-foun', 'FOUNDRY', '✅ Context grounded: Enterprise policies loaded');
  await sleep(500);
  
  if (cmdLower.includes('scan')) {
    addLog('tag-act', 'ACTION', '🔎 Running vulnerability scan...');
    await sleep(600);
    addLog('tag-act', 'ACTION', '📋 Vulnerabilities detected, analyzing CVEs');
    await sleep(500);
    addLog('tag-act', 'ACTION', '🛠 Auto-remediation initiated');
  } else {
    addLog('tag-act', 'ACTION', '⚙ Executing command through pipeline...');
    await sleep(600);
    addLog('tag-act', 'ACTION', '✅ Command processed successfully');
  }
  
  setStep(4);
  updateNodes(5);
  updateStatus('SECURE');
  const trace = 'TR-' + Date.now().toString().slice(-8);
  traceIdEl.textContent = trace;
  addLog('tag-audit', 'AUDIT', `🔒 Pipeline CLOSED. Status: SECURE // Trace: ${trace}`);
});
</script>
</body>
</html>

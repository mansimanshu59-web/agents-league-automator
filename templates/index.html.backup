<title>SECURE-IQ | AGENT COMMAND</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Space+Mono:wght@400;700&family=Inter:wght@300;400;600;800;900&display=swap" rel="stylesheet">
<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: linear-gradient(135deg, #FFF8E7 0%, #F5E6D3 100%);
  font-family: 'Inter', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
  cursor: none;
  position: relative;
}

/* ========== ULTRA CUSTOM CURSOR ========== */
#cursor-glow {
  position: fixed;
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(197,160,89,0.15), transparent 70%);
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: all 0.2s;
}

#cursor-core {
  position: fixed;
  width: 10px;
  height: 10px;
  background: #C5A059;
  border-radius: 50%;
  pointer-events: none;
  z-index: 10000;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 20px #D4A574;
}

#cursor-trail {
  position: fixed;
  width: 6px;
  height: 6px;
  background: #D4A574;
  border-radius: 50%;
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%, -50%);
  opacity: 0.4;
  filter: blur(2px);
}

.touch-ripple {
  position: fixed;
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(197,160,89,0.4), transparent);
  pointer-events: none;
  z-index: 9997;
  transform: translate(-50%, -50%) scale(0);
  animation: rippleBurst 0.8s ease-out forwards;
}

@keyframes rippleBurst {
  0% { transform: translate(-50%, -50%) scale(0); opacity: 0.8; }
  100% { transform: translate(-50%, -50%) scale(4); opacity: 0; }
}

/* Canvas Layers */
#three-canvas-main {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}

#three-canvas-particles {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

/* Main Container */
.container {
  position: relative;
  z-index: 10;
  max-width: 1600px;
  margin: 0 auto;
  padding: 25px 30px;
}

/* Soft Glass Navigation */
nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20px;
  margin-bottom: 45px;
  padding: 15px 30px;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20px);
  border-radius: 80px;
  border: 1px solid rgba(197, 160, 89, 0.2);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
}

.logo {
  display: flex;
  align-items: center;
  gap: 12px;
}

.logo-mark {
  width: 50px;
  height: 50px;
  background: linear-gradient(135deg, #C5A059, #D4A574);
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 5px 20px rgba(197, 160, 89, 0.3);
  animation: softPulse 3s ease-in-out infinite;
}

@keyframes softPulse {
  0%, 100% { transform: scale(1); box-shadow: 0 5px 20px rgba(197, 160, 89, 0.3); }
  50% { transform: scale(1.02); box-shadow: 0 8px 30px rgba(197, 160, 89, 0.5); }
}

.logo-txt {
  font-family: 'Orbitron', monospace;
  font-size: 22px;
  font-weight: 900;
  letter-spacing: 5px;
  background: linear-gradient(135deg, #C5A059, #8B6914);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.nav-links {
  display: flex;
  gap: 35px;
  list-style: none;
}

.nav-links a {
  font-size: 12px;
  letter-spacing: 2px;
  color: #5C4033;
  text-decoration: none;
  text-transform: uppercase;
  font-weight: 600;
  transition: all 0.3s;
  position: relative;
}

.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -5px;
  left: 0;
  width: 0;
  height: 2px;
  background: linear-gradient(90deg, #C5A059, #D4A574);
  transition: width 0.3s;
}

.nav-links a:hover::after {
  width: 100%;
}

.nav-links a:hover {
  color: #C5A059;
}

.status-pill {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 22px;
  background: rgba(197, 160, 89, 0.1);
  border-radius: 100px;
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: #C5A059;
  border: 1px solid rgba(197, 160, 89, 0.3);
  backdrop-filter: blur(5px);
}

.status-dot {
  width: 10px;
  height: 10px;
  background: #4CAF50;
  border-radius: 50%;
  animation: softPulse 1.5s infinite;
  box-shadow: 0 0 10px #4CAF50;
}

/* Hero Grid */
.hero {
  display: grid;
  grid-template-columns: 1fr;
  gap: 35px;
}

@media (min-width: 1024px) {
  .hero {
    grid-template-columns: 1fr 1fr;
    gap: 60px;
  }
}

/* Typography */
.big-title {
  font-size: clamp(56px, 9vw, 108px);
  font-weight: 900;
  line-height: 0.9;
  letter-spacing: -4px;
  background: linear-gradient(135deg, #C5A059, #8B6914, #D4A574);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  margin-bottom: 20px;
  animation: titleFloat 4s ease-in-out infinite;
}

@keyframes titleFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5px); }
}

.sub-title {
  font-family: 'Orbitron', monospace;
  font-size: 13px;
  letter-spacing: 5px;
  color: #A0845C;
  margin-bottom: 25px;
}

.tagline {
  font-size: 15px;
  color: #6B4E3A;
  line-height: 1.7;
  border-left: 3px solid #C5A059;
  padding-left: 20px;
  margin-bottom: 35px;
}

/* Soft Card */
.cmd-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(15px);
  border-radius: 32px;
  padding: 32px;
  border: 1px solid rgba(197, 160, 89, 0.2);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.cmd-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 30px 50px rgba(197, 160, 89, 0.15);
  border-color: rgba(197, 160, 89, 0.4);
}

.cmd-label {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  letter-spacing: 3px;
  color: #C5A059;
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.cmd-input {
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(197, 160, 89, 0.3);
  border-radius: 20px;
  padding: 18px;
  color: #2C1810;
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  outline: none;
  resize: vertical;
  min-height: 120px;
  transition: all 0.3s;
}

.cmd-input:focus {
  border-color: #C5A059;
  box-shadow: 0 0 25px rgba(197, 160, 89, 0.2);
}

.run-btn {
  width: 100%;
  margin-top: 20px;
  padding: 18px;
  background: linear-gradient(135deg, #C5A059, #D4A574);
  border: none;
  border-radius: 20px;
  color: white;
  font-family: 'Orbitron', monospace;
  font-size: 14px;
  font-weight: 900;
  letter-spacing: 4px;
  cursor: pointer;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.run-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.5s;
}

.run-btn:hover::before {
  left: 100%;
}

.run-btn:hover {
  transform: scale(1.02);
  box-shadow: 0 10px 30px rgba(197, 160, 89, 0.4);
}

/* IQ Pills */
.iq-row {
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
  margin-top: 25px;
}

.iq-pill {
  padding: 10px 22px;
  border-radius: 100px;
  font-size: 11px;
  letter-spacing: 2px;
  font-weight: 700;
  text-transform: uppercase;
  font-family: 'Space Mono', monospace;
  border: 1px solid;
  cursor: pointer;
  transition: all 0.3s;
  backdrop-filter: blur(5px);
}

.iq-pill:hover {
  transform: translateY(-3px);
}

.iq-pill-1 {
  background: rgba(197, 160, 89, 0.1);
  border-color: #C5A059;
  color: #C5A059;
}

.iq-pill-2 {
  background: rgba(212, 165, 116, 0.1);
  border-color: #D4A574;
  color: #D4A574;
}

.iq-pill-3 {
  background: linear-gradient(135deg, #C5A059, #D4A574);
  border-color: transparent;
  color: white;
}

/* Log Card */
.log-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(15px);
  border-radius: 32px;
  overflow: hidden;
  border: 1px solid rgba(197, 160, 89, 0.2);
  margin-bottom: 20px;
  transition: all 0.3s;
}

.log-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 40px rgba(197, 160, 89, 0.1);
}

.log-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
  background: rgba(197, 160, 89, 0.1);
  border-bottom: 1px solid rgba(197, 160, 89, 0.2);
}

.log-header-text {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  letter-spacing: 2px;
  color: #C5A059;
}

.log-body {
  padding: 20px 24px;
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  min-height: 280px;
  max-height: 300px;
  overflow-y: auto;
}

.log-entry {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(197, 160, 89, 0.1);
  flex-wrap: wrap;
  animation: slideInUp 0.4s ease-out;
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(15px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.log-time {
  color: #A0845C;
  min-width: 65px;
  font-size: 9px;
}

.log-tag {
  font-size: 8px;
  padding: 3px 12px;
  border-radius: 8px;
  font-weight: 700;
}

.tag-audit { background: #C5A059; color: white; }
.tag-user { background: #D4A574; color: white; }
.tag-sec { background: #E8A598; color: white; }
.tag-foun { background: #C5A059; color: white; }
.tag-act { background: rgba(197, 160, 89, 0.2); color: #C5A059; border: 1px solid #C5A059; }

.log-message {
  color: #5C4033;
  font-size: 10px;
  flex: 1;
  word-break: break-word;
}

/* Metrics Grid */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin-bottom: 20px;
}

.metric-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  border-radius: 24px;
  padding: 22px 12px;
  text-align: center;
  border: 1px solid rgba(197, 160, 89, 0.2);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
  overflow: hidden;
}

.metric-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(197, 160, 89, 0.1), transparent);
  transition: left 0.5s;
}

.metric-card:hover::before {
  left: 100%;
}

.metric-card:hover {
  transform: translateY(-8px) scale(1.02);
  border-color: #C5A059;
  box-shadow: 0 15px 30px rgba(197, 160, 89, 0.15);
}

.metric-card:nth-child(1) .metric-value { color: #C5A059; }
.metric-card:nth-child(2) .metric-value { color: #D4A574; }
.metric-card:nth-child(3) .metric-value { color: #A0845C; }

.metric-value {
  font-size: 44px;
  font-weight: 900;
  font-family: 'Orbitron', monospace;
  animation: numberPop 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes numberPop {
  0% { transform: scale(0.3); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.metric-label {
  font-size: 9px;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-top: 10px;
  font-family: 'Space Mono', monospace;
  color: #A0845C;
}

/* Pipeline Card */
.pipeline-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(15px);
  border-radius: 28px;
  padding: 24px;
  border: 1px solid rgba(197, 160, 89, 0.2);
  overflow-x: auto;
  transition: all 0.3s;
}

.pipeline-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 15px 30px rgba(197, 160, 89, 0.1);
}

.pipeline-label {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  letter-spacing: 2px;
  color: #A0845C;
  margin-bottom: 20px;
}

.pipeline-steps {
  display: flex;
  align-items: center;
  min-width: 550px;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  min-width: 80px;
}

.step-icon {
  width: 55px;
  height: 55px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  border: 2px solid;
  background: rgba(255, 255, 255, 0.6);
}

.step-icon.idle {
  border-color: rgba(197, 160, 89, 0.3);
  color: rgba(197, 160, 89, 0.4);
}

.step-icon.active {
  border-color: #C5A059;
  background: rgba(197, 160, 89, 0.15);
  color: #C5A059;
  box-shadow: 0 0 30px rgba(197, 160, 89, 0.4);
  animation: bounceStep 0.6s infinite alternate;
}

@keyframes bounceStep {
  to {
    transform: scale(1.08);
  }
}

.step-icon.completed {
  border-color: #4CAF50;
  background: rgba(76, 175, 80, 0.15);
  color: #4CAF50;
  box-shadow: 0 0 20px rgba(76, 175, 80, 0.3);
}

.step-name {
  font-family: 'Space Mono', monospace;
  font-size: 8px;
  letter-spacing: 1px;
  color: #A0845C;
  text-align: center;
}

.connector {
  flex: 1;
  height: 3px;
  background: rgba(197, 160, 89, 0.2);
  margin-bottom: 32px;
  position: relative;
  overflow: hidden;
}

.connector.active {
  background: linear-gradient(90deg, #C5A059, #D4A574);
  animation: flowGradient 1s linear infinite;
  background-size: 200% 100%;
}

@keyframes flowGradient {
  0% { background-position: 0% 0%; }
  100% { background-position: 200% 0%; }
}

/* Footer */
footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 10px;
  margin-top: 50px;
  border-top: 1px solid rgba(197, 160, 89, 0.2);
  flex-wrap: wrap;
  gap: 10px;
}

.footer-text {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 2px;
  color: #A0845C;
}

/* Scrollbar */
.log-body::-webkit-scrollbar {
  width: 5px;
}
.log-body::-webkit-scrollbar-track {
  background: rgba(197, 160, 89, 0.1);
  border-radius: 5px;
}
.log-body::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, #C5A059, #D4A574);
  border-radius: 5px;
}
</style>
</head>
<body>

<!-- Cursor Layers -->
<div id="cursor-glow"></div>
<div id="cursor-core"></div>
<div id="cursor-trail"></div>

<!-- 3D Canvases -->
<canvas id="three-canvas-main"></canvas>
<canvas id="three-canvas-particles"></canvas>

<div class="container">
  <nav>
    <div class="logo">
      <div class="logo-mark">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="#C5A059" stroke-width="1.5"/>
          <circle cx="12" cy="12" r="6" stroke="#D4A574" stroke-width="1"/>
          <circle cx="12" cy="12" r="2.5" fill="#C5A059"/>
        </svg>
      </div>
      <span class="logo-txt">SECURE-IQ</span>
    </div>
    <ul class="nav-links">
      <li><a href="#">Workflow</a></li>
      <li><a href="#">Process</a></li>
      <li><a href="#">Configuration</a></li>
    </ul>
    <div class="status-pill">
      <div class="status-dot"></div>
      SECURE // ACTIVE
    </div>
  </nav>

  <div class="hero">
    <div class="left">
      <div>
        <div class="big-title">AGENT<br>COMMAND</div>
        <div class="sub-title">// MICROSOFT FOUNDRY IQ</div>
      </div>
      <p class="tagline">Enterprise reasoning pipeline with real-time knowledge grounding. Autonomous threat detection & remediation at scale.</p>

      <div class="cmd-card">
        <div class="cmd-label">
          <span>⚡</span> ENTERPRISE COMMAND PROMPT
        </div>
        <textarea class="cmd-input" id="commandInput" placeholder='Example: "Scan network for vulnerabilities and patch CVEs"'></textarea>
        <button class="run-btn" id="runBtn">🚀 TRIGGER AGENT WORKFLOW</button>
      </div>

      <div class="iq-row">
        <div class="iq-pill iq-pill-1">⬡ Foundry IQ</div>
        <div class="iq-pill iq-pill-2">⊞ Work IQ</div>
        <div class="iq-pill iq-pill-3">◈ Fabric IQ</div>
      </div>
    </div>

    <div class="right">
      <div class="log-card">
        <div class="log-header">
          <div class="log-header-text">// INTELLIGENCE NODE LOGS</div>
          <div style="display: flex; gap: 8px;">
            <span style="width: 10px; height: 10px; background: #E8A598; border-radius: 50%;"></span>
            <span style="width: 10px; height: 10px; background: #C5A059; border-radius: 50%;"></span>
            <span style="width: 10px; height: 10px; background: #4CAF50; border-radius: 50%;"></span>
          </div>
        </div>
        <div class="log-body" id="logContainer">
          <div class="log-entry">
            <span class="log-time">--:--:--</span>
            <span class="log-tag tag-audit">AUDIT</span>
            <span class="log-message">MS_FOUNDRY_IQ. Standby mode active. Awaiting pipeline dispatch...</span>
          </div>
        </div>
      </div>

      <div class="metrics-grid">
        <div class="metric-card">
          <div class="metric-value" id="threatScore">0%</div>
          <div class="metric-label">Threat Score</div>
        </div>
        <div class="metric-card">
          <div class="metric-value" id="nodeCount">0</div>
          <div class="metric-label">Nodes Active</div>
        </div>
        <div class="metric-card">
          <div class="metric-value" id="pipelineStatus">IDLE</div>
          <div class="metric-label">Pipeline</div>
        </div>
      </div>

      <div class="pipeline-card">
        <div class="pipeline-label">// REASONING PIPELINE</div>
        <div class="pipeline-steps">
          <div class="step">
            <div class="step-icon idle" id="step0">🛡️</div>
            <div class="step-name">Zero Trust</div>
          </div>
          <div class="connector" id="conn0"></div>
          <div class="step">
            <div class="step-icon idle" id="step1">📊</div>
            <div class="step-name">Metrics</div>
          </div>
          <div class="connector" id="conn1"></div>
          <div class="step">
            <div class="step-icon idle" id="step2">☁️</div>
            <div class="step-name">Foundry IQ</div>
          </div>
          <div class="connector" id="conn2"></div>
          <div class="step">
            <div class="step-icon idle" id="step3">⚙️</div>
            <div class="step-name">Action</div>
          </div>
          <div class="connector" id="conn3"></div>
          <div class="step">
            <div class="step-icon idle" id="step4">✅</div>
            <div class="step-name">Resolved</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer>
    <div class="footer-text">SECURE-IQ v3.0 // <strong>FOUNDRY IQ LIVE</strong></div>
    <div class="footer-text">AGENTS LEAGUE 2026 // <span>REASONING TRACK</span></div>
    <div class="footer-text">TRACE: <span id="traceId">IDLE</span></div>
